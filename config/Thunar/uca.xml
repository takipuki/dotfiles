<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open Terminal Here</name>
	<submenu></submenu>
	<unique-id>1715605142253717-1</unique-id>
	<command>exo-open --working-directory %f --launch TerminalEmulator</command>
	<description>Example for a custom action</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>archive-extract</icon>
	<name>7x</name>
	<submenu></submenu>
	<unique-id>1718196683674139-1</unique-id>
	<command>7z x %n -o&quot;$(echo %n | sed -E &apos;s/\.[^\.]+$//&apos;)&quot; &amp;&amp; notify-send Extracted -t 1000 || notify-send Failed</command>
	<description></description>
	<range></range>
	<patterns>*.rar;*.zip;*.7z</patterns>
	<other-files/>
</action>
<action>
	<icon>archive-insert</icon>
	<name>zip</name>
	<submenu></submenu>
	<unique-id>1718197330591378-2</unique-id>
	<command>7z a tmp.zip %N</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
