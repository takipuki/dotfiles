	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon></icon>
	<name>m3u</name>
	<submenu></submenu>
	<unique-id>1723123188123017-1</unique-id>
	<command>echo %N | sed -E &apos;s|(\.[^\. ]+) |\1\n|g&apos; &gt; 0.m3u</command>
